# Step 0/99: shared resource prefix used by setup and cleanup.
WORKSHOP_RESOURCE_PREFIX=foundry-workshop

# Step 1+: Foundry project endpoint and model deployment.
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Step 3: MCP server settings. Defaults target OctoTrip Flights MCP.
MCP_SERVER_LABEL=octotrip-flights
MCP_SERVER_URL=https://mcp.octotrip.app/flights/mcp

# Step 5: Azure AI Search endpoint and index for RAG.
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX_NAME=

# Step 6 (Part B): comma-separated Foundry skill name(s) the agent downloads at
# runtime. Leave empty until Part B (Part A does not use it); after you upload the
# skill in Part B, set FOUNDRY_SKILL_NAMES=response-guardrails
FOUNDRY_SKILL_NAMES=

# Step 9: Foundry Memory store name and embedding model deployment.
MEMORY_STORE_NAME=
AZURE_AI_EMBEDDING_MODEL_DEPLOYMENT_NAME=
